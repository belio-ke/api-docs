{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Belio Docs",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "api": {
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "defaults": "required",
      "prefill": true
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "REST API",
        "groups": [
          {
            "group": "REST API",
            "pages": [
              "overview"
            ]
          },
          {
            "group": "Authentication",
            "pages": [
              "authentication/introduction",
              "authentication/bearer-token"
            ]
          },
          {
            "group": "Services",
            "pages": [
              "service/list"
            ]
          },
          {
            "group": "Messaging",
            "pages": [
              "messaging/introduction",
              {
                "group": "SMS",
                "pages": [
                  "messaging/sms/introduction",
                  "messaging/sms/send",
                  "messaging/sms/delivery-receipt"
                ]
              },
              {
                "group": "WhatsApp",
                "tag": "COMING SOON",
                "pages": [
                  "messaging/whatsapp/introduction",
                  {
                    "group": "Templates",
                    "pages": [
                      "messaging/whatsapp/templates/introduction",
                      "messaging/whatsapp/templates/create-template",
                      "messaging/whatsapp/templates/view-templates"
                    ]
                  },
                  "messaging/whatsapp/send",
                  "messaging/whatsapp/delivery-receipt"
                ]
              }
            ]
          },
          {
            "group": "Mobile Data",
            "pages": [
              "mobile-data/introduction",
              "mobile-data/send",
              "mobile-data/delivery-receipt"
            ]
          },
          {
            "group": "Bundles",
            "pages": [
              "bundle/list"
            ]
          },
          {
            "group": "Campaigns",
            "pages": [
              "campaign/list"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://belio.co.ke",
          "icon": "link"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:info@belio.co.ke"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://cloud.belio.co.ke"
    }
  }
}
